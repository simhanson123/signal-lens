{
  "name": "review-mcp",
  "version": "1.3.0",
  "description": "MCP-based AI PR review and maintainer automation agent",
  "type": "module",
  "bin": {
    "review-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/simhanson123/review-mcp.git"
  },
  "homepage": "https://github.com/simhanson123/review-mcp#readme",
  "bugs": {
    "url": "https://github.com/simhanson123/review-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "fixtures": "npm run build && node dist/scripts/generate-fixture-snapshots.js",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "pull-request",
    "code-review",
    "github-action",
    "maintainer",
    "open-source",
    "sarif",
    "tree-sitter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.0",
    "@octokit/webhooks": "^14.0.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "minisearch": "^7.1.2",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.8",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}